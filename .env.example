# Required — Azure AD App Registration
SHAREPOINT_TENANT_ID=your-azure-ad-tenant-id
SHAREPOINT_CLIENT_ID=your-azure-ad-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-ad-client-secret

# Optional — restrict to a specific SharePoint site
# SHAREPOINT_SITE_URL=https://yourorg.sharepoint.com/sites/your-site

# Optional — upload limits
# SHAREPOINT_MAX_UPLOAD_BYTES=0           # 0 = unlimited
# SHAREPOINT_MAX_PAGINATION_RESULTS=500   # safety cap for list operations
